# ============================================================

server <- function(input, output, session) {

  sel <- reactiveVal(NULL)

  # Sync hero search → selected district
  observeEvent(input$hero_search, {
    req(input$hero_search)
    sel(as.integer(input$hero_search))
  })
  observeEvent(input$sel_cd, {
    sel(as.integer(input$sel_cd))
    updateSelectizeInput(session, "hero_search", selected=as.character(input$sel_cd))
  })

  # ── HERO MAP ──────────────────────────────────────────────
  output$map_hero <- renderLeaflet({
    leaflet(options=leafletOptions(zoomControl=FALSE)) %>%
      addProviderTiles("CartoDB.Positron") %>%
      setView(lng=-73.95, lat=40.70, zoom=9) %>%
      addPolygons(
        data        = master_sf,
        layerId     = ~boro_cd,
        fillColor   = ~tier_pal(priority_tier),
        fillOpacity = 0.6,
        color       = "#ffffff", weight=1,
        label       = ~lapply(apply(master_sf,1,function(r) make_tt(as.list(r))),HTML),
        labelOptions = lbl_opts,
        highlight   = highlightOptions(weight=2,color='#14532d',
                        fillOpacity=0.85, bringToFront=TRUE)
      )
  })

  observeEvent(input$map_hero_shape_click, {
    req(input$map_hero_shape_click$id)
    sel(as.integer(input$map_hero_shape_click$id))
    updateSelectizeInput(session,"hero_search",
      selected=as.character(input$map_hero_shape_click$id))
  })

  # Highlight selected on hero map
  observe({
    s <- sel(); req(s)
    feat <- master_sf %>% filter(boro_cd==s)
    if (nrow(feat)>0) {
      bb <- st_bbox(feat)
      leafletProxy("map_hero") %>%
        clearGroup("selected") %>%
        addPolygons(data=feat, group="selected",
          fillColor="#14532d", fillOpacity=0.85,
          color="#ffffff", weight=2.5)
    }
  })

  # ── HERO PROFILE CARD ────────────────────────────────────
  output$hero_profile <- renderUI({
    s <- sel()
    if (is.null(s)) return(NULL)
    d <- master %>% filter(boro_cd==s)
    if (nrow(d)==0) return(NULL)
    d <- d[1,]

    tc    <- as.character(d$priority_tier)
    col   <- tier_colors[tc]
    bg    <- paste0(col,"18")

    fmt <- function(x, digits=1, suf="", mult=1) {
      if (is.na(x)) "N/A" else paste0(round(x*mult, digits), suf)
    }
    vs_park <- if (!is.na(d$park_acres_per_capita)) {
      diff <- d$park_acres_per_capita - nyc_avg_park
      cls  <- if (diff >= 0) "vs-good" else "vs-bad"
      sign <- if (diff >= 0) "+" else ""
      tags$span(class=cls, paste0(sign, round(diff*1000,2), " vs avg"))
    } else NULL
    vs_pov <- if (!is.na(d$poverty_rate)) {
      diff <- d$poverty_rate - nyc_avg_poverty
      cls  <- if (diff <= 0) "vs-good" else "vs-bad"
      sign <- if (diff > 0) "+" else ""
      tags$span(class=cls, paste0(sign, round(diff,1),"% vs avg"))
    } else NULL
    vs_hvi <- if (!is.na(d$hvi)) {
      diff <- d$hvi - nyc_avg_hvi
      cls  <- if (diff <= 0) "vs-good" else "vs-bad"
      sign <- if (diff > 0) "+" else ""
      tags$span(class=cls, paste0(sign, round(diff,2)," vs avg"))
    } else NULL

    park_pct <- if(!is.na(d$park_acres_per_capita)) min(d$park_acres_per_capita/0.016*100,100) else 0
    pov_pct  <- if(!is.na(d$poverty_rate))  min(d$poverty_rate/45*100,100) else 0
    hvi_pct  <- if(!is.na(d$hvi))           min((d$hvi-1)/4*100,100) else 0

    div(class="profile-card",
      div(class="profile-name", d$district_name),
      div(class="profile-tier",
          style=paste0("background:",bg,";color:",col,";border:1px solid ",col), tc),
      div(class="profile-metrics",
        div(class="pm",
          div(class="pm-label","Park Access"),
          div(class="pm-value", fmt(d$park_acres_per_capita,2," ac/1k",1000)),
          div(class="pm-avg",
            paste0("NYC avg: ",round(nyc_avg_park*1000,2)," ac/1k  "), vs_park),
          div(class="pm-bar",
            div(class="pm-fill",
                style=paste0("width:",park_pct,"%;background:#16a34a")))
        ),
        div(class="pm",
          div(class="pm-label","Poverty Rate"),
          div(class="pm-value", fmt(d$poverty_rate,1,"%")),
          div(class="pm-avg",
            paste0("NYC avg: ",round(nyc_avg_poverty,1),"%  "), vs_pov),
          div(class="pm-bar",
            div(class="pm-fill",
                style=paste0("width:",pov_pct,"%;background:#7c3aed")))
        ),
        div(class="pm",
          div(class="pm-label","Heat Vulnerability Index"),
          div(class="pm-value", fmt(d$hvi,2)),
          div(class="pm-avg",
            paste0("NYC avg: ",round(nyc_avg_hvi,2),"  "), vs_hvi),
          div(class="pm-bar",
            div(class="pm-fill",
                style=paste0("width:",hvi_pct,"%;background:#dc2626")))
        ),
        div(class="pm",
          div(class="pm-label","Population"),
          div(class="pm-value",
              format(d$population, big.mark=",")),
          div(class="pm-avg",
            paste0("Park rank: #",d$park_rank_desc," of ",n_districts))
        )
      )
    )
  })

  # ── SECTION 2: PARK ACCESS MAP ───────────────────────────
  output$park_rank_ui <- renderUI({
    df <- master %>%
      filter(!is.na(park_acres_per_capita)) %>%
      arrange(park_acres_per_capita) %>% head(15)
    s <- sel()
    tagList(lapply(seq_len(nrow(df)), function(i) {
      d  <- df[i,]
      div(class=paste("rank-row", if(!is.null(s)&&s==d$boro_cd)"sel" else ""),
          onclick=paste0("Shiny.setInputValue('sel_cd',",d$boro_cd,",{priority:'event'})"),
          div(class="rank-num", i),
          div(class="rank-name", title=d$district_name, d$short_name),
          div(class="rank-val", style="color:var(--red)",
              paste0(round(d$park_acres_per_capita*1000,2),"ac"))
      )
    }))
  })

  output$map_park <- renderLeaflet({
    leaflet(options=leafletOptions(zoomControl=TRUE)) %>%
      addProviderTiles("CartoDB.Positron") %>%
      setView(lng=-73.95, lat=40.70, zoom=10) %>%
      addPolygons(
        data        = master_sf,
        layerId     = ~boro_cd,
        fillColor   = ~park_pal(park_acres_per_capita),
        fillOpacity = 0.7,
        color       = "#ffffff", weight=0.8,
        label       = ~lapply(apply(master_sf,1,function(r) make_tt(as.list(r))),HTML),
        labelOptions = lbl_opts,
        highlight   = highlightOptions(weight=2,color="#14532d",
                        fillOpacity=0.9, bringToFront=TRUE)
      ) %>%
      addLegend("bottomleft", pal=park_pal, values=master$park_acres_per_capita,
        title="Park ac/capita", opacity=0.9,
        labFormat=labelFormat(transform=function(x) round(x*1000,2), suffix=" /1k"))
  })

  observeEvent(input$map_park_shape_click, {
    req(input$map_park_shape_click$id)
    sel(as.integer(input$map_park_shape_click$id))
    updateSelectizeInput(session,"hero_search",
      selected=as.character(input$map_park_shape_click$id))
  })

  # ── SECTION 3: INEQUALITY SCATTER ────────────────────────
  s3_df <- reactive({
    df <- master %>%
      filter(!is.na(park_acres_per_capita), !is.na(poverty_rate), !is.na(pct_nonwhite))
    if (!is.null(input$s3_pov))   df <- df %>% filter(poverty_rate >= input$s3_pov)
    if (!is.null(input$s3_nw))    df <- df %>% filter(pct_nonwhite*100 >= input$s3_nw)
    if (!is.null(input$s3_boro) && length(input$s3_boro)>0)
      df <- df %>% filter(borough %in% input$s3_boro)
    df
  })

  output$s3_count <- renderText(paste0(nrow(s3_df()), " districts"))

  output$scatter_ineq <- renderPlotly({
    df  <- s3_df()
    sel_cd <- sel()
    req(nrow(df)>0)
    df$is_sel <- !is.null(sel_cd) & df$boro_cd == sel_cd

    plot_ly() %>%
      add_trace(
        data      = df %>% filter(!is_sel),
        x         = ~park_acres_per_capita*1000,
        y         = ~poverty_rate,
        color     = ~pct_nonwhite*100,
        colors    = c("#dcfce7","#4ade80","#16a34a","#14532d"),
        size      = ~population, sizes=c(6,40),
        type="scatter", mode="markers",
        marker    = list(opacity=0.75,
                    line=list(width=0.5,color="rgba(255,255,255,0.6)")),
        text      = ~paste0("<b>",district_name,"</b><br>",
                            "Park: ",round(park_acres_per_capita*1000,2)," ac/1k<br>",
                            "Poverty: ",round(poverty_rate,1),"%<br>",
                            "Non-white: ",round(pct_nonwhite*100,1),"%<br>",
                            "Pop: ",format(population,big.mark=",")),
        hoverinfo = "text", name="Districts"
      ) %>%
      add_trace(
        data      = df %>% filter(is_sel),
        x         = ~park_acres_per_capita*1000,
        y         = ~poverty_rate,
        type="scatter", mode="markers+text",
        marker    = list(color="#14532d",size=14,opacity=1,
                    symbol="star",line=list(width=2,color="#ffffff")),
        text      = ~short_name, textposition="top right",
        textfont  = list(color="#14532d",size=11,family="Inter"),
        hoverinfo = "text", name="Selected"
      ) %>%
      layout(
        paper_bgcolor = "#ffffff", plot_bgcolor="#f8faf8",
        font   = list(family="Inter", color="#111827", size=11),
        xaxis  = list(title="Park Acres per 1,000 Population",
                      gridcolor="#e5e7eb", zerolinecolor="#e5e7eb"),
        yaxis  = list(title="Poverty Rate (%)",
                      gridcolor="#e5e7eb", zerolinecolor="#e5e7eb"),
        coloraxis = list(
          colorbar=list(title="% Non-white",
            tickfont=list(color="#6b7280"),
            titlefont=list(color="#6b7280"))
        ),
        legend = list(font=list(color="#6b7280")),
        margin = list(l=50,r=20,t=20,b=50),
        shapes = list(
          list(type="line", x0=nyc_avg_park*1000, x1=nyc_avg_park*1000,
               y0=0, y1=50, line=list(color="#16a34a",dash="dot",width=1.5)),
          list(type="line", x0=0, x1=25, y0=nyc_avg_poverty, y1=nyc_avg_poverty,
               line=list(color="#7c3aed",dash="dot",width=1.5))
        ),
        annotations = list(
          list(x=0.02,y=0.97,xref="paper",yref="paper",
               text="← Low park + high poverty",
               showarrow=FALSE,font=list(size=10,color="#dc2626"),xanchor="left"),
          list(x=nyc_avg_park*1000+0.1,y=2,xref="x",yref="y",
               text="NYC avg park",showarrow=FALSE,
               font=list(size=9,color="#16a34a"),xanchor="left"),
          list(x=0.5,y=nyc_avg_poverty+0.5,xref="x",yref="y",
               text="NYC avg poverty",showarrow=FALSE,
               font=list(size=9,color="#7c3aed"),xanchor="left")
        )
      ) %>%
      config(displayModeBar=FALSE)
  })

  # ── SECTION 4: HEAT SCATTER + MAP ────────────────────────
  output$scatter_heat <- renderPlotly({
    df     <- master %>% filter(!is.na(park_acres_per_capita),!is.na(hvi))
    sel_cd <- sel()
    df$is_sel <- !is.null(sel_cd) & df$boro_cd==sel_cd

    plot_ly() %>%
      add_trace(
        data      = df %>% filter(!is_sel),
        x         = ~park_acres_per_capita*1000,
        y         = ~hvi,
        color     = ~poverty_rate,
        colors    = c("#f0fdf4","#86efac","#16a34a","#7c3aed","#4c1d95"),
        size      = ~population, sizes=c(6,40),
        type="scatter", mode="markers",
        marker    = list(opacity=0.75,
                    line=list(width=0.5,color="rgba(255,255,255,0.6)")),
        text      = ~paste0("<b>",district_name,"</b><br>",
                            "Park: ",round(park_acres_per_capita*1000,2)," ac/1k<br>",
                            "HVI: ",round(hvi,2),"<br>",
                            "Poverty: ",round(poverty_rate,1),"%"),
        hoverinfo = "text", name="Districts"
      ) %>%
      add_trace(
        data      = df %>% filter(is_sel),
        x         = ~park_acres_per_capita*1000,
        y         = ~hvi,
        type="scatter", mode="markers+text",
        marker    = list(color="#14532d",size=14,opacity=1,
                    symbol="star",line=list(width=2,color="#ffffff")),
        text      = ~short_name, textposition="top right",
        textfont  = list(color="#14532d",size=11,family="Inter"),
        hoverinfo = "text", name="Selected"
      ) %>%
      layout(
        paper_bgcolor="#ffffff", plot_bgcolor="#f8faf8",
        font   = list(family="Inter",color="#111827",size=11),
        xaxis  = list(title="Park Acres per 1,000 Population",
                      gridcolor="#e5e7eb",zerolinecolor="#e5e7eb"),
        yaxis  = list(title="Heat Vulnerability Index",
                      gridcolor="#e5e7eb",zerolinecolor="#e5e7eb"),
        coloraxis = list(
          colorbar=list(title="Poverty Rate (%)",
            tickfont=list(color="#6b7280"),
            titlefont=list(color="#6b7280"))
        ),
        legend = list(font=list(color="#6b7280")),
        margin = list(l=50,r=20,t=20,b=50),
        shapes = list(
          list(type="rect",x0=0,x1=1,y0=3.5,y1=6,
               fillcolor="rgba(220,38,38,0.06)",
               line=list(color="rgba(220,38,38,0.25)",width=1)),
          list(type="line",x0=nyc_avg_park*1000,x1=nyc_avg_park*1000,
               y0=0,y1=6,line=list(color="#16a34a",dash="dot",width=1.5)),
          list(type="line",x0=0,x1=20,y0=nyc_avg_hvi,y1=nyc_avg_hvi,
               line=list(color="#dc2626",dash="dot",width=1.5))
        ),
        annotations = list(
          list(x=0.02,y=0.97,xref="paper",yref="paper",
               text="▲ High risk: low park + high heat",
               showarrow=FALSE,font=list(size=10,color="#dc2626"),xanchor="left")
        )
      ) %>%
      config(displayModeBar=FALSE)
  })

  output$map_hvi <- renderLeaflet({
    leaflet(options=leafletOptions(zoomControl=FALSE)) %>%
      addProviderTiles("CartoDB.Positron") %>%
      setView(lng=-73.95,lat=40.70,zoom=9) %>%
      addPolygons(
        data        = master_sf, layerId=~boro_cd,
        fillColor   = ~hvi_pal(hvi), fillOpacity=0.75,
        color="#ffffff", weight=0.8,
        label       = ~lapply(apply(master_sf,1,function(r) make_tt(as.list(r))),HTML),
        labelOptions = lbl_opts,
        highlight   = highlightOptions(weight=2,color="#14532d",
                        fillOpacity=0.9,bringToFront=TRUE)
      ) %>%
      addLegend("bottomleft",pal=hvi_pal,values=master$hvi,
        title="Heat Vulnerability Index",opacity=0.9)
  })

  observeEvent(input$map_hvi_shape_click, {
    req(input$map_hvi_shape_click$id)
    sel(as.integer(input$map_hvi_shape_click$id))
    updateSelectizeInput(session,"hero_search",
      selected=as.character(input$map_hvi_shape_click$id))
  })

  # ── SECTION 5: PRIORITY MAP ──────────────────────────────

  # Active tier chips
  active_tiers <- reactive({
    chips <- input$s5_chips
    map_c <- c("vh"="Very high priority","hi"="High priority",
                "mo"="Moderate priority","lo"="Lower priority")
    if (is.null(chips)||chips=="") return(unname(map_c))
    unname(map_c[str_split(chips,",")[[1]]])
  })

  # Simulated scores
  sim_data <- eventReactive(input$apply_sim, {
    total <- input$w_park + input$w_poverty + input$w_hvi
    if (total==0) return(master %>% mutate(sim_tier=priority_tier))
    wp <- input$w_park/total
    wv <- input$w_poverty/total
    wh <- input$w_hvi/total
    master %>%
      mutate(
        sim_score = park_norm*wp + poverty_norm*wv + hvi_norm*wh,
        sim_tier  = factor(case_when(
          sim_score >= quantile(sim_score,0.75,na.rm=TRUE) ~ "Very high priority",
          sim_score >= quantile(sim_score,0.50,na.rm=TRUE) ~ "High priority",
          sim_score >= quantile(sim_score,0.25,na.rm=TRUE) ~ "Moderate priority",
          TRUE ~ "Lower priority"),
          levels=c("Very high priority","High priority","Moderate priority","Lower priority"))
      )
  }, ignoreNULL=FALSE)

  output$sim_check <- renderUI({
    total <- (if(is.null(input$w_park) || is.na(input$w_park)) 44 else input$w_park) +
             (if(is.null(input$w_poverty) || is.na(input$w_poverty)) 25 else input$w_poverty) +
             (if(is.null(input$w_hvi) || is.na(input$w_hvi)) 31 else input$w_hvi)
    col <- if(total==100) "var(--green)" else "var(--orange)"
    ok  <- if(total==100) " ✓" else " (adjust to reach 100)"
    div(style=paste0("font-size:10px;color:",col,";margin-top:-4px"),
      paste0("Total: ",total,"%",ok))
  })

  output$priority_rank_ui <- renderUI({
    df_sim <- sim_data()
    tiers  <- active_tiers()
    df <- df_sim %>%
      filter(as.character(priority_tier) %in% tiers) %>%
      arrange(desc(overall_score)) %>% head(12)
    s <- sel()
    tagList(lapply(seq_len(nrow(df)), function(i) {
      d  <- df[i,]
      tc <- as.character(d$priority_tier)
      co <- tier_colors[tc]
      div(class=paste("rank-row",if(!is.null(s)&&s==d$boro_cd)"sel"else""),
          onclick=paste0("Shiny.setInputValue('sel_cd',",d$boro_cd,",{priority:'event'})"),
          div(class="rank-num",i),
          div(class="rank-name",title=d$district_name,d$short_name),
          div(class="rank-val",style=paste0("color:",co),d$overall_score)
      )
    }))
  })

  output$map_priority <- renderLeaflet({
    leaflet(options=leafletOptions(zoomControl=TRUE)) %>%
      addProviderTiles("CartoDB.Positron") %>%
      setView(lng=-73.95,lat=40.70,zoom=10)
  })

  observe({
    df_sim <- sim_data()
    tiers  <- active_tiers()
    s      <- sel()

    sf_plot <- master_sf %>%
      left_join(df_sim %>% select(boro_cd,sim_tier), by="boro_cd") %>%
      mutate(
        display_tier = if("sim_tier" %in% names(.)) sim_tier else priority_tier,
        visible = as.character(display_tier) %in% tiers
      )

    leafletProxy("map_priority") %>%
      clearShapes() %>% clearControls() %>%
      addPolygons(
        data        = sf_plot, layerId=~boro_cd,
        fillColor   = ~ifelse(visible, tier_pal(display_tier), "#e5e7eb"),
        fillOpacity = ~ifelse(!is.null(s)&boro_cd==s, 0.95,
                       ifelse(visible, 0.7, 0.2)),
        color       = ~ifelse(!is.null(s)&boro_cd==s,"#14532d",
                       ifelse(visible, "#ffffff","#d1d5db")),
        weight      = ~ifelse(!is.null(s)&boro_cd==s, 3, 0.8),
        label       = ~lapply(apply(sf_plot,1,function(r) make_tt(as.list(r))),HTML),
        labelOptions = lbl_opts,
        highlight   = highlightOptions(weight=2,color="#14532d",
                        fillOpacity=0.9,bringToFront=TRUE)
      ) %>%
      addLegend("bottomleft",
        colors  = unname(tier_colors),
        labels  = names(tier_colors),
        title   = "Priority Tier",
        opacity = 0.9
      )
  })

  observeEvent(input$map_priority_shape_click, {
    req(input$map_priority_shape_click$id)
    sel(as.integer(input$map_priority_shape_click$id))
    updateSelectizeInput(session,"hero_search",
      selected=as.character(input$map_priority_shape_click$id))
  })

  # Priority detail + breakdown
  output$priority_detail <- renderUI({
    s <- sel()
    if (is.null(s)) return(NULL)
    d <- master %>% filter(boro_cd==s)
    if (nrow(d)==0) return(NULL)
    d  <- d[1,]
    tc <- as.character(d$priority_tier)
    co <- tier_colors[tc]
    bg <- paste0(co,"15")

    div(class="card",
      div(class="card-hd",
        d$district_name, " — ",
        tags$span(style=paste0("background:",bg,";color:",co,
          ";padding:2px 8px;border-radius:8px;font-size:11px;border:1px solid ",co),
          tc)
      ),
      div(class="card-body",
        div(style="display:flex;gap:16px;align-items:flex-start",
          # Score
          div(style=paste0("font-size:40px;font-family:'Playfair Display',serif;",
            "color:",co,";line-height:1;flex-shrink:0"),
            d$overall_score,
            div(style="font-size:11px;color:var(--muted);font-family:'Inter',sans-serif",
              "out of 12")
          ),
          # Breakdown bars
          div(class="breakdown", style="flex:1",
            div(class="bd-row",
              div(class="bd-hd",
                div(class="bd-lbl","Park Access (43.75%)"),
                div(class="bd-val",paste0(d$park_rank,"/4"))),
              div(class="bd-track",
                div(class="bd-fill",
                    style=paste0("width:",round(d$park_rank/4*100),
                      "%;background:#16a34a")))
            ),
            div(class="bd-row",
              div(class="bd-hd",
                div(class="bd-lbl","Poverty (25%)"),
                div(class="bd-val",paste0(d$poverty_rank,"/4"))),
              div(class="bd-track",
                div(class="bd-fill",
                    style=paste0("width:",round(d$poverty_rank/4*100),
                      "%;background:#7c3aed")))
            ),
            div(class="bd-row",
              div(class="bd-hd",
                div(class="bd-lbl","Heat/HVI (31.25%)"),
                div(class="bd-val",paste0(d$hvi_rank,"/4"))),
              div(class="bd-track",
                div(class="bd-fill",
                    style=paste0("width:",round(d$hvi_rank/4*100),
                      "%;background:#dc2626")))
            )
          )
        )
      )
    )
  })

  # ── COMPARE TABLE ─────────────────────────────────────────
  output$compare_table <- renderTable({
    req(input$cmp_a, input$cmp_b)
    da <- master %>% filter(boro_cd==as.integer(input$cmp_a)) %>% slice(1)
    db <- master %>% filter(boro_cd==as.integer(input$cmp_b)) %>% slice(1)
    req(nrow(da)>0, nrow(db)>0)

    fmt <- function(x, digits=2, suf="", mult=1) {
      if(is.na(x)) "N/A" else paste0(round(x*mult,digits),suf)
    }

    col_a <- da$short_name
    col_b <- db$short_name
    tbl <- tibble(
      Metric        = c("Overall Priority Score","Priority Tier",
                        "Park Access (ac/1k pop)","Total Park Acres",
                        "Population","Poverty Rate",
                        "Heat Vulnerability Index","% Non-white",
                        "Park Rank (NYC)"),
      A             = c(
        paste0(da$overall_score,"/12"),
        as.character(da$priority_tier),
        fmt(da$park_acres_per_capita,3,mult=1000),
        fmt(da$park_acres,1," ac"),
        format(da$population,big.mark=","),
        fmt(da$poverty_rate,1,"%"),
        fmt(da$hvi,2),
        fmt(da$pct_nonwhite,1,"%",100),
        paste0("#",da$park_rank_desc," of ",n_districts)
      ),
      B             = c(
        paste0(db$overall_score,"/12"),
        as.character(db$priority_tier),
        fmt(db$park_acres_per_capita,3,mult=1000),
        fmt(db$park_acres,1," ac"),
        format(db$population,big.mark=","),
        fmt(db$poverty_rate,1,"%"),
        fmt(db$hvi,2),
        fmt(db$pct_nonwhite,1,"%",100),
        paste0("#",db$park_rank_desc," of ",n_districts)
      )
    )
    names(tbl)[2] <- col_a
    names(tbl)[3] <- col_b
    tbl
  }, striped=TRUE, hover=TRUE, bordered=FALSE,
     colnames=TRUE, width="100%"
  )
}

