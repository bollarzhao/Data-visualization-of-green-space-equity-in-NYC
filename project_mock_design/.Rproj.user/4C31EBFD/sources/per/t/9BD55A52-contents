valid_boro_cds <- c(101:112, 201:212, 301:318, 401:414, 501:503)

master <- master_raw %>%
  filter(boro_cd %in% valid_boro_cds) %>%
  mutate(
    short_name = district_name %>%
      str_replace("Manhattan Community District", "MN CD") %>%
      str_replace("Bronx Community District",     "BX CD") %>%
      str_replace("Brooklyn Community District",  "BK CD") %>%
      str_replace("Queens Community District",    "QN CD") %>%
      str_replace("Staten Island Community District", "SI CD"),

    borough = case_when(
      str_starts(as.character(boro_cd), "1") ~ "Manhattan",
      str_starts(as.character(boro_cd), "2") ~ "Bronx",
      str_starts(as.character(boro_cd), "3") ~ "Brooklyn",
      str_starts(as.character(boro_cd), "4") ~ "Queens",
      str_starts(as.character(boro_cd), "5") ~ "Staten Island"
    ),

    priority_tier = factor(priority_tier,
      levels = c("Very high priority","High priority",
                 "Moderate priority","Lower priority")),

    park_norm    = (max(park_acres_per_capita, na.rm=TRUE) - park_acres_per_capita) /
                   (max(park_acres_per_capita, na.rm=TRUE) - min(park_acres_per_capita, na.rm=TRUE)),
    poverty_norm = (poverty_rate - min(poverty_rate, na.rm=TRUE)) /
                   (max(poverty_rate, na.rm=TRUE) - min(poverty_rate, na.rm=TRUE)),
    hvi_norm     = (hvi - min(hvi, na.rm=TRUE)) /
                   (max(hvi, na.rm=TRUE) - min(hvi, na.rm=TRUE)),

    park_rank_asc  = rank(park_acres_per_capita,  na.last = "keep"),
    park_rank_desc = rank(-park_acres_per_capita, na.last = "keep"),

    # Ensure rank columns exist (use CSV values if present, else compute)
    park_rank    = if ("park_rank"    %in% names(.)) as.integer(park_rank)    else ntile(desc(park_acres_per_capita), 4),
    poverty_rank = if ("poverty_rank" %in% names(.)) as.integer(poverty_rank) else ntile(poverty_rate, 4),
    hvi_rank     = if ("hvi_rank"     %in% names(.)) as.integer(hvi_rank)     else ntile(hvi, 4)
  )

