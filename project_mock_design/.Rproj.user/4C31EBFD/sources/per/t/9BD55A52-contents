make_tt <- function(d) {
  park_str <- if (!is.na(d$park_acres_per_capita))
    paste0(round(d$park_acres_per_capita*1000,2)," ac/1k") else "N/A"
  pov_str  <- if (!is.na(d$poverty_rate))  paste0(round(d$poverty_rate,1),"%") else "N/A"
  hvi_str  <- if (!is.na(d$hvi))           round(d$hvi,2) else "N/A"
  tier_col <- tier_colors[as.character(d$priority_tier)]
  HTML(paste0(
    "<div class='tt-hd'>",d$district_name,"</div>",
    "<div class='tt-bd'>",
    "<div class='tt-r'><span class='tt-k'>Priority</span>",
    "<span style='color:",tier_col,";font-weight:700'>",d$priority_tier,"</span></div>",
    "<div class='tt-r'><span class='tt-k'>Score</span>",
    "<span class='tt-v'>",d$overall_score,"/12</span></div>",
    "<div class='tt-r'><span class='tt-k'>Park access</span>",
    "<span class='tt-v'>",park_str,"</span></div>",
    "<div class='tt-r'><span class='tt-k'>Poverty rate</span>",
    "<span class='tt-v'>",pov_str,"</span></div>",
    "<div class='tt-r'><span class='tt-k'>HVI</span>",
    "<span class='tt-v'>",hvi_str,"</span></div>",
    "</div>"
  ))
}

